ETCD_NAME="{{ ansible_hostname }}"
ETCD_LISTEN_CLIENT_URLS="http://{{ etcd_hostname | default(hostvars[inventory_hostname]['ansible_'+ ansible_default_ipv4.interface | replace('-', '_')]['ipv4']['address'], true) }}:2379,http://127.0.0.1:2379"
ETCD_ADVERTISE_CLIENT_URLS="http://{{ etcd_hostname }}:2379"
ETCD_LISTEN_PEER_URLS="http://{{ etcd_hostname | default(hostvars[inventory_hostname]['ansible_'+ ansible_default_ipv4.interface | replace('-', '_')]['ipv4']['address'], true) }}:2380"
ETCD_INITIAL_ADVERTISE_PEER_URLS="http://{{ etcd_hostname | default(hostvars[inventory_hostname]['ansible_'+ ansible_default_ipv4.interface | replace('-', '_')]['ipv4']['address'], true) }}:2380"
ETCD_INITIAL_CLUSTER_TOKEN="{{ etcd_cluster_name }}"
ETCD_INITIAL_CLUSTER="{% for host in groups['etcd_cluster'] %}{{ hostvars[host]['ansible_hostname'] }}=http://{{ hostvars[host]['etcd_hostname'] }}:2380{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_INITIAL_CLUSTER_STATE="{{ etcd_cluster_state | default('new')}}"
ETCD_DATA_DIR="{{ etcd_data_dir }}"
ETCD_ELECTION_TIMEOUT="5000"
ETCD_HEARTBEAT_INTERVAL="1000"
ETCD_INITIAL_ELECTION_TICK_ADVANCE="false"
ETCD_LOG_LEVEL="{{ etcd_log_level }}"
